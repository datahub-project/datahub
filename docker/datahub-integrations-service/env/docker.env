DATAHUB_GMS_PROTOCOL=http
DATAHUB_GMS_HOST=datahub-gms
DATAHUB_GMS_PORT=8080

# System Auth -- Used for communicating with DataHub GMS.
DATAHUB_SYSTEM_CLIENT_ID=__datahub_system
DATAHUB_SYSTEM_CLIENT_SECRET=JohnSnowKnowsNothing

# Kafka consumer group prefix for automations.
# Each automation action gets its own consumer group named: {prefix}_{action_urn}
# This ensures each action receives all events it should process.
# Do NOT use KAFKA_PROPERTIES_GROUP_ID - it would cause all actions to share one consumer group.
KAFKA_AUTOMATIONS_CONSUMER_GROUP_PREFIX=datahub

# Use for testing webhooks locally.
#DEV_MODE_OVERRIDE_DATAHUB_FRONTEND_URL=