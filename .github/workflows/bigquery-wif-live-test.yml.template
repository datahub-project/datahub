# Rename this file to bigquery-wif-live-test.yml to activate.

name: BigQuery WIF live test

on:
  workflow_dispatch:
  pull_request:
    paths:
      - "metadata-ingestion/src/datahub/ingestion/source/bigquery_v2/**"
      - "metadata-ingestion/src/datahub/ingestion/source/common/gcp_wif_config.py"
      - "metadata-ingestion/tests/integration/bigquery_wif/**"
      - ".github/workflows/bigquery-wif-live-test.yml"

permissions:
  contents: read
  id-token: write # required for OIDC token minting

jobs:
  live-wif:
    name: Live BigQuery WIF
    runs-on: ubuntu-latest
    # Skip on PRs from forks — repo variables aren't exposed there.
    if: github.event.pull_request.head.repo.full_name == github.repository || github.event_name == 'workflow_dispatch'
    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-python@v5
        with:
          python-version: "3.11"

      - name: Authenticate to GCP via WIF
        id: auth
        uses: google-github-actions/auth@v2
        with:
          workload_identity_provider: ${{ vars.GCP_WIF_PROVIDER }}
          service_account: ${{ vars.GCP_WIF_SERVICE_ACCOUNT }}
          create_credentials_file: true
          # Do not export GOOGLE_APPLICATION_CREDENTIALS — the test consumes
          # the credentials path explicitly via BIGQUERY_WIF_CONFIG_PATH, which
          # mirrors how BigQueryConnectionConfig is used in production.
          export_environment_variables: false

      - name: Install datahub
        working-directory: metadata-ingestion
        run: |
          python -m pip install -U pip
          pip install -e ".[bigquery]" -c constraints.txt
          pip install pytest

      - name: Run live WIF test
        working-directory: metadata-ingestion
        env:
          BIGQUERY_WIF_CONFIG_PATH: ${{ steps.auth.outputs.credentials_file_path }}
          BIGQUERY_WIF_PROJECT_ID: ${{ vars.GCP_PROJECT_ID }}
        run: pytest tests/integration/bigquery_wif/test_live_wif.py -v
