# Bedrock Configuration for DataHub Integrations Service
# Copy this file to bedrock.env and customize for your environment

# AWS Configuration for Bedrock
# Option 1: Use AWS Profile (recommended for local development with SSO)
AWS_PROFILE=acryl-read-write

# Option 2: Use explicit credentials (not recommended)
# BEDROCK_AWS_ACCESS_KEY_ID=your_access_key_here
# BEDROCK_AWS_SECRET_ACCESS_KEY=your_secret_key_here

# AWS Region for Bedrock
BEDROCK_AWS_REGION=us-west-2

# Bedrock Model Configuration
BEDROCK_EMBEDDING_MODEL=cohere.embed-english-v3
BEDROCK_EMBEDDING_DIMENSIONS=1024

# Performance Settings
BEDROCK_MAX_ATTEMPTS=4
ENABLE_BEDROCK_OPTIMIZED_LATENCY=false
ENABLE_BEDROCK_PROMPT_CACHING=true

DATAHUB_TELEMETRY_ENABLED=false
MLFLOW_TRACKING_URI=arn:aws:sagemaker:us-west-2:795586375822:mlflow-tracking-server/prod-mlflow-tracking-server-01
MLFLOW_TRACKING_AWS_SIGV4=true
MLFLOW_S3_UPLOAD_EXTRA_ARGS={"ServerSideEncryption": "AES256"}
DATAHUB_INTEGRATIONS_SEND_TELEMETRY_EVENTS=false


# For AWS SSO:
# 1. Run: aws sso login --profile your-profile-name
# 2. Set AWS_PROFILE to your profile name
# 3. Restart the container to pick up credentials
