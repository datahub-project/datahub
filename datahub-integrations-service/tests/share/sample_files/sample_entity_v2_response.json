      "version": 0,
      "value": {
        "viewLanguage": "SQL",
        "viewLogic": "CREATE MATERIALIZED VIEW tickets_mv AS\n    select   catgroup,\n    sum(qtysold) as sold\n    from     category c, event e, sales s\n    where    c.catid = e.catid\n    and      e.eventid = s.eventid\n    group by catgroup",
        "materialized": true
      }
