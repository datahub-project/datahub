{
    "entityType": "dataJob",
    "entityUrn": "urn:li:dataJob:(urn:li:dataFlow:(mariadb,test_db.stored_procedures,PROD),generate_order_summaries)",
    "changeType": "UPSERT",
    "aspectName": "dataTransformLogic",
    "aspect": {
        "json": {
            "transforms": [
                {
                    "queryStatement": {
                        "value": "BEGIN\n    \n    DELETE FROM customer_order_summary;\n\n    \n    INSERT INTO customer_order_summary (\n        customer_id,\n        total_orders,\n        total_spent,\n        last_order_date\n    )\n    SELECT\n        rc.id as customer_id,\n        COUNT(ro.id) as total_orders,\n        SUM(ro.order_total) as total_spent,\n        MAX(ro.created_at) as last_order_date\n    FROM raw_customer_data rc\n    LEFT JOIN raw_order_data ro ON rc.id = ro.customer_id\n    GROUP BY rc.id\n    HAVING SUM(ro.order_total) >= min_order_total;\nEND",
                        "language": "SQL"
                    }
                }
            ]
        }
    },
    "systemMetadata": {
        "lastObserved": 1713074400694,
        "runId": "mariadb-test",
        "lastRunId": "no-run-id-provided"
    }
},
