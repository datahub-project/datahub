    "changeType": "UPSERT",
    "aspectName": "viewProperties",
    "aspect": {
        "json": {
            "materialized": false,
            "viewLogic": "<Calculation:scenario xmlns:Calculation=\"http://www.sap.com/ndb/BiModelCalculation.ecore\"\n                      xmlns:xsi=\"http://www.w3.org/2001/XMLSchema-instance\"\n                      calculationScenarioType=\"SCRIPT_BASED\">\n  <dataSources/>\n  <calculationViews>\n    <calculationView xsi:type=\"Calculation:SqlScriptView\" id=\"Script_View\">\n      <viewAttributes>\n        <viewAttribute id=\"CUST_ID\"/>\n        <viewAttribute id=\"REVENUE\"/>\n      </viewAttributes>\n      <definition>BEGIN\n  RESULT_SET = SELECT \"ID\" AS \"CUST_ID\", \"TOTAL\" AS \"REVENUE\"\n               FROM \"REPORTING\".\"SALES\"\n               JOIN \"REPORTING\".\"CUSTOMERS\"\n                 ON \"SALES\".\"CUST_ID\" = \"CUSTOMERS\".\"ID\";\nEND</definition>\n    </calculationView>\n  </calculationViews>\n  <logicalModel id=\"Script_View\">\n    <attributes>\n      <attribute id=\"CUST_ID\">\n        <keyMapping columnObjectName=\"Script_View\" columnName=\"CUST_ID\"/>\n      </attribute>\n    </attributes>\n    <baseMeasures>\n      <measure id=\"REVENUE\">\n        <measureMapping columnObjectName=\"Script_View\" columnName=\"REVENUE\"/>\n      </measure>\n    </baseMeasures>\n  </logicalModel>\n</Calculation:scenario>\n",
            "viewLanguage": "UNKNOWN"
        }
