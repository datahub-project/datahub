{
  "type": "s3",
  "config": {
    "path_specs": [
      {
        "include": "s3://my-test-bucket/folders_only_media/*/*/",
        "emit_folders_only": true
      }
    ],
    "aws_config": {
      "aws_region": "us-east-1",
      "aws_access_key_id": "testing",
      "aws_secret_access_key": "testing"
    },
    "profiling": {
      "enabled": false
    }
  }
}
