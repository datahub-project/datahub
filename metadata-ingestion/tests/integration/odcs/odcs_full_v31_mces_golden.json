            "rawContract": "apiVersion: v3.1.0\nkind: DataContract\nid: 00000000-0000-0000-0000-000000000002\nname: customers_full\nversion: 2.1.0\nstatus: active\ndomain: customers\ndataProduct: customer-360\ntenant: acme\nfrobozz: 42                       # unknown field \u2014 exercises D5 extras-warning\ndescription:\n  purpose: Customer master records used by the CDP.\n  usage: Joinable to orders and events on customer_id.\n  limitations: Non-PII columns only available outside the data perimeter.\ntags:\n  - finance\n  - pii\nteam:\n  - username: alice\n    role: owner\n  - username: bob\n    role: dataSteward\n  - username: bob\n    role: dataSteward          # exact duplicate \u2013 should dedup\n  - username: carol\n    role: businessOwner\n  - username: dave\n    role: owner\n    dateOut: \"2024-01-01\"      # excluded\n  - username: \"group:platform-team\"\n    role: dataOwner\n  - username: erin\n    role: someUnmappedRole     # falls back to TECHNICAL_OWNER\nservers:\n  - server: prod-postgres\n    type: postgres\n    host: postgres.example.internal\n    port: 5432\n    database: customers_db\n    schema: public\n  - server: prod-snowflake\n    type: snowflake\n    account: acme-prod\n    database: ANALYTICS\n    schema: PUBLIC\nschema:\n  - name: customers\n    physicalName: customers\n    description: Master table of customers.\n    tags:\n      - core\n    properties:\n      - name: id\n        physicalName: id\n        logicalType: number\n        primaryKey: true\n        required: true\n        description: Surrogate key.\n        quality:\n          - name: id_not_null\n            rule: notNull\n      - name: email\n        physicalName: email\n        logicalType: string\n        required: true\n        tags:\n          - pii\n        classification: confidential\n        description: Primary contact email for the customer.\n        quality:\n          - name: email_unique\n            rule: unique\n      - name: profile\n        physicalName: profile\n        logicalType: object\n        description: Nested profile struct.\n        properties:\n          - name: country\n            logicalType: string\n            quality:\n              - name: country_not_null\n                rule: notNull\n          - name: score\n            logicalType: number\n            quality:\n              - name: score_in_range\n                rule: range          # unknown library \u2014 falls through to CustomAssertion\n                mustBeBetween: [0, 100]\n    quality:\n      - name: customers_row_count\n        rule: rowCount\n        mustBeGreaterOrEqualTo: 100\n      - name: customers_row_count_not_in_range\n        rule: rowCount\n        mustNotBeBetween: [1, 10]      # exercises D6 routing-to-custom\n  - name: orders\n    physicalName: orders\n    description: Order events.\n    properties:\n      - name: order_id\n        logicalType: number\n        primaryKey: true\n      - name: customer_id\n        logicalType: number\nquality:\n  - name: customers_have_emails\n    type: sql\n    query: SELECT COUNT(*) FROM customers WHERE email IS NULL\n    mustBeGreaterThan: 0\n"
