#!/usr/bin/env bash
# Rejects any push that changes more than MAX_FILES files. Guards against
# accidental massive pushes (vendored trees, generated output, node_modules, ...).
# Bypass a deliberate large push with: git push --no-verify

MAX_FILES=500
# git sends one line per ref on stdin: <local_ref> <local_oid> <remote_ref> <remote_oid>
files="$(
  while read -r local_ref local_oid remote_ref remote_oid; do
    # ${oid//0/} strips zeros; empty result means an all-zero oid (SHA-1 or SHA-256).
    [ -z "${local_oid//0/}" ] && continue                   # deleting a remote ref
    if [ -z "${remote_oid//0/}" ]; then
      # New remote ref: only commits not already on any remote branch.
      git log --name-only --pretty=format: "$local_oid" --not --remotes -- 2>/dev/null || true
    else
      # Updating an existing ref: net diff between old and new tip.
      git diff --name-only "$remote_oid" "$local_oid" -- 2>/dev/null || true
    fi
  done | sed '/^$/d' | sort -u
)"

# fail-open on any git error above (|| true) — this is an accident guard,
# not a security control, so a stale/missing object must never block a real push.

count=0
[ -n "$files" ] && count=$(printf '%s\n' "$files" | wc -l | tr -d ' ')

if [ "$count" -gt "$MAX_FILES" ]; then
  echo "pre-push: this push changes $count files (limit $MAX_FILES) — refusing." >&2
  echo "pre-push: Agents: Never bypass this with --no-verify. Ask the user to check the commits." >&2
  echo "pre-push: Humans: if this is intentional, re-run with: git push --no-verify" >&2
  exit 1
fi

exit 0
