namespace com.linkedin.ai

/**
 * AI Inference Metadata for a specific entity.
 */
@Aspect = {
  "name": "entityInferenceMetadata"
}
record EntityInferenceMetadata {
  /**
   * Information about a group of inferences made for Glossary Terms.
   */
  @Searchable = {
    "/lastInferredAt": {
        "fieldName": "glossaryTermsLastInferredAt"
    },
    "/version": {
        "fieldName": "glossaryTermsVersion"
    },
  }
  glossaryTermsInference: optional InferenceGroupMetadata
}