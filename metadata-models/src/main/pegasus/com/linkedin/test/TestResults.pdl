namespace com.linkedin.test

/**
 * Information about a Test Result
 */
@Aspect = {
 "name": "testResults"
}
record TestResults {
  /**
   * Results that are failing
   */
  @Searchable = {
    "/*/test": {
      "fieldType": "URN",
      "fieldName": "failingTests"
      "hasValuesFieldName": "hasFailingTests",
    },
    "/*/testDefinitionMd5": {
      "fieldType": "KEYWORD",
      "fieldName": "failingTestDefinitionMd5"
    }
  }
  @Relationship = {
    "/*/test": {
      "name": "IsFailing",
      "entityTypes": [ "test" ]
    }
  }
  failing: array[TestResult]

  /**
   * Results that are passing
   */
  @Searchable = {
    "/*/test": {
      "fieldType": "URN",
      "fieldName": "passingTests",
      "hasValuesFieldName": "hasPassingTests",
    },
    "/*/testDefinitionMd5": {
      "fieldType": "KEYWORD",
      "fieldName": "passingTestDefinitionMd5"
    }
  }
  @Relationship = {
    "/*/test": {
      "name": "IsPassing",
      "entityTypes": [ "test" ]
    }
  }
  passing: array[TestResult]
}