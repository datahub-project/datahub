namespace com.linkedin.executorglobalconfig

/**
 * Global singleton storing configs for remote executor pools.
 */
@Aspect = {
  "name": "dataHubRemoteExecutorPoolGlobalConfig"
}
record RemoteExecutorPoolGlobalConfig {
    /**
     * The default pool to use for tasks that require remote executors.
     * References 'poolName' in com.linkedin.metadata.key.RemoteExecutorKey
     */
    defaultPoolName: string
}