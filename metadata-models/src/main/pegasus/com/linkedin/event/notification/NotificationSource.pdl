namespace com.linkedin.event.notification

import com.linkedin.common.ActorType
import com.linkedin.common.Urn

/**
 * Notification source information.
 */
@Aspect = {
    "name": "notificationSource"
}
record NotificationSource {
    /**
     * Notification source type
     */
    sourceType: NotificationSourceType

    /**
    * Notification source Urn
    */
    @Searchable = {
        "fieldType": "URN"
    }
    sourceUrn: optional Urn
}