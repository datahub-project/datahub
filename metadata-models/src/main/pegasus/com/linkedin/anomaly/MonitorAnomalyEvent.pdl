namespace com.linkedin.anomaly

import com.linkedin.common.EntityReference
import com.linkedin.common.Urn
import com.linkedin.common.TimeStamp
import com.linkedin.timeseries.TimeseriesAspectBase

/**
 * Information about an anomaly generated by a monitor
 * NOTE: the timestampMillis field must match the timestampMillis of the assertionRunEvent that corresponds to the anomaly.
 */
@Aspect = {
  "name": "monitorAnomalyEvent",
  "type": "timeseries",
}
record MonitorAnomalyEvent includes TimeseriesAspectBase {
  /**
   * The review of the anomaly, based on human-provided feedback.
   * If this is not present, then the Anomaly has not yet been reviewed.
   */
  @TimeseriesField = {}
  state: optional enum AnomalyReviewState {
    /**
     * The anomaly has been confirmed by a human reviewer. This means the anomaly was validated.
     */
    CONFIRMED
    /**
     * The anomaly has been dismissed, or ignored, by a human reviewer. This means the anomaly should have been ignored.
     */
    REJECTED
  }

  /**
   * The source of an anomaly, i.e. how it was generated.
   */
  source: AnomalySource

  /**
   * The time at which the anomaly was initially created
   * If this anomaly is INFERRED_ASSERTION_FAILURE, then this will be the same as the assertionRunEvent's timestampMillis.
   * If this anomaly is USER_FEEDBACK, then this will be the time at which the anomaly was reported.
   */
  @TimeseriesField = {}
  created: TimeStamp

  /**
   * The time at which the anomaly was last updated
   */
  @TimeseriesField = {}
  lastUpdated: TimeStamp
}