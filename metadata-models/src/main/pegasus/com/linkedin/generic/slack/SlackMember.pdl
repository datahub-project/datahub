 * Namespace for the urn of this entity should be 'slack-member'. See GenericEntityKey.pdl for details.
 */
@Aspect = {
  "name": "slackMember"
}
record SlackMember includes SlackEntityBase {
  /**
   * The email associated with the Slack member.
   */
  email: optional string
}
