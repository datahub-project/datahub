namespace com.linkedin.executorpool

import com.linkedin.common.Urn


@Aspect = {
  "name": "dataHubRemoteExecutorPoolInfo"
}
record RemoteExecutorPoolInfo {

  /**
   * UTC-based timestamp of when this pool was created
   */
  @Searchable = {
    "fieldType": "COUNT",
    "queryByDefault": false
  }
  createdAt: long

  /**
   * The creator of this pool
   */
  creator: Urn

}
