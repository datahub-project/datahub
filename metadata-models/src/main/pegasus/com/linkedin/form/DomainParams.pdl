namespace com.linkedin.form

import com.linkedin.common.Urn

/**
 * Information specific to glossary terms prompts.
 */
record DomainParams {
  /**
   * An optional list of allowed domains to choose from
   */
  @Relationship = {
    "/*": {
      "name": "allowedDomainOn",
      "entityTypes": [ "domain" ]
    }
  }
  allowedDomains: optional array[Urn]
}
