namespace com.linkedin.metadata.key

/**
 * Key for a CorpUser
 */
@Aspect = {
  "name": "corpUserKey",
  "schemaVersion": 2
}
record CorpUserKey {
  /**
  * The name of the AD/LDAP user.
  */
  @Searchable = {
    "fieldName": "ldap",
    "fieldType": "WORD_GRAM",
    "boostScore": 2.0,
    "enableAutocomplete": true,
    "searchTier": 1
  }
  username: string
}
