namespace com.linkedin.metric

/**
 * Describes whether a metric can be fully reconstructed from its sources
 * if its storage is lost.
 */
enum Recoverability {
  /** Metric can be fully recomputed from upstream sources. */
  FULL
  /** Metric can be partially recomputed; some historical data may be lost. */
  PARTIAL
  /** Metric cannot be recomputed from available sources. */
  NONE
}
