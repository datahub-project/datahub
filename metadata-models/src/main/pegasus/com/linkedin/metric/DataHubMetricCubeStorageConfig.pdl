namespace com.linkedin.metric

/**
 * The metric storage configurations.
 */
@Aspect = { "name": "dataHubMetricCubeStorageConfig" }
record DataHubMetricCubeStorageConfig {
    /**
     * The retention configurations for the metric cube.
     */
    retention: DataHubMetricCubeRetentionConfig

    /**
     * The aggregation configurations for the metric cube.
     */
    aggregation: DataHubMetricCubeAggregationConfig
}