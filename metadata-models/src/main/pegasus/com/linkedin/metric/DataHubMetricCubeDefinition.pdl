namespace com.linkedin.metric

/**
 * The structure of an individual metric cube in DataHub.
 */
@Aspect = { name = "dataHubMetricCubeDefinition" }
record DataHubMetricCubeDefinition {
  /**
  *  Name of the metric
  */
  name: string

  /**
  *  Optional description for the metric
  */
  description: optional string

  /**
  *  The measures of the cube
  */
  measures: DataHubMetricCubeMeasures

  /**
  * The dimensions of the cube
  */
  dimensions: DataHubMetricCubeDimensions
}