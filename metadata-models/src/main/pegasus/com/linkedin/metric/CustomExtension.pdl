namespace com.linkedin.metric

/**
 * A vendor-namespaced extension blob that carries platform-specific metric metadata
 * not expressible in the OSI core schema (Proposal B §B.5).
 * The content field must be a valid JSON string.
 */
record CustomExtension {

  /**
   * Reverse-DNS vendor namespace, e.g. "com.dbt" or "com.snowflake".
   */
  vendor: string

  /**
   * JSON-encoded extension payload whose schema is defined by the vendor.
   */
  content: string
}
