namespace com.linkedin.common

/**
 * Misc. properties about an entity.
 */
record CustomProperties {
  /**
   * Custom property bag.
   */
  @Searchable = {
    "/*": {
      "fieldType": "TEXT",
      "queryByDefault": true,
      "searchTier": 2
    }
  }
  customProperties: map[string, string] = { }
}