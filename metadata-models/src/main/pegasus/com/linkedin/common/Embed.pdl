namespace com.linkedin.common

/**
 * Information regarding rendering an embed for an asset.
 */
@Aspect = {
  "name": "embed",
  "schemaVersion": 4
}
record Embed {
  /**
   * The type of embed e.g. iframe, video.
   */
  embedType: optional string

  /**
   * The title of the embed.
   */
  embedTitle: optional string
}