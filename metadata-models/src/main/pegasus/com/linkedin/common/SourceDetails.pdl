namespace com.linkedin.common

/**
 * Info about how this asset was ingested into this system
 */
record SourceDetails {
 /**
  * Urn of the source of this asset. Could be an ingestion source, an acryl
    platform instance, etc.
  */
  source: Urn

 /**
  * Urn of the platform this asset was synced from ie. urn:li:dataPlatform:snowflake for snowflake ingestion
  * or urn:li:dataPlatform:acryl for assets synced from another catalog instance.
  */
  sourcePlatform: Urn

 /**
  * Audit stamp for when this asset was synced
  */
  lastModified: AuditStamp

 /**
  * The means by which this asset got synchronized
  */
  mechanism: enum SyncMechanism {
    /**
    * Synced via ingestion
    */
    INGEST
    /**
    * Synced via metadata sharing with another acryl instance
    */
    SHARE
    /**
    * Synced via the API
    */
    API
    /**
    * Synced via some other mechanism
    */
    OTHER
  }

 /**
  * Additional information related to the source of this metadata
  */
  sourceDetails: optional map[string, string] = { }
}
