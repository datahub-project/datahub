namespace com.linkedin.monitor

import com.linkedin.timeseries.TimeseriesAspectBase
import com.linkedin.common.CustomProperties

/**
 * Stats required to evaluate continuous monitors.
 */
@Aspect = {
  "name": "monitorTimeseriesState",
  "type": "timeseries",
}
record MonitorTimeseriesState includes TimeseriesAspectBase, CustomProperties {
  /**
   * An optional identifier for the state. Useful for partitioning + filtering state.
   */
  @TimeseriesField = {}
  id: optional string
}