namespace com.linkedin.monitor

/**
 * Information about an Assertion monitor.
 */
record AssertionMonitor {
    /**
    * Specs for each assertion to evaluate
    */
    assertions: array[AssertionEvaluationSpec]

    /**
    * Specific settings for an assertion monitor
    */
    settings: optional AssertionMonitorSettings

    /**
     * The status of the bootstrap actions performed on the assertion.
     */
    bootstrapStatus: optional AssertionMonitorBootstrapStatus
}
