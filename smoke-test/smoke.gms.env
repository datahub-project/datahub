# This file contains environment variables for the DataHub GMS service during smoke tests.
# It's used to configure the GMS service with specific settings needed for testing.
# The file is referenced by the DATAHUB_LOCAL_GMS_ENV environment variable in run-quickstart.sh,
# which is then used by docker-compose to load these variables into the GMS service container.
# This approach follows the pattern used in docker-compose.gms.yml for loading environment variables.

# Telemetry and logging environment variables
ENABLE_THIRD_PARTY_LOGGING=false
DATAHUB_TELEMETRY_ENABLED=false
# Mixpanel specific variables - set them appropriately if you want to run Mixpanel smoke tests manually
MIXPANEL_ENABLED=false
# MIXPANEL_TOKEN=27...d5a  <-- get from 1Passwd

METADATA_TESTS_ENABLED=true
METADATA_TESTS_BOOTSTRAP_ENABLED=true
METADATA_TESTS_BOOTSTRAP_ACTIVE_DEFAULTS=true
