{
  "permissions": {
    "allow": [
      "Bash(cd:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr view:*)",
      "Bash(git diff:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(sed:*)",
      "Bash(find:*)",
      "Bash(rg:*)",
      "WebFetch(domain:docs.datahub.com)",
      "Bash(mypy:*)",
      "Bash(pytest:*)",
      "Bash(ruff:*)",
      "Bash(python -m mypy:*)",
      "Bash(python -m ruff:*)",
      "Bash(python -m pytest:*)",
      "Bash(yarn:*)",
      "Bash(./gradlew:*)",
      "Bash(../gradlew :metadata-ingestion:lintFix:*)",
      "Bash(gw:*)"
    ],
    "deny": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/deny-git-no-verify.sh\""
          }
        ]
      }
    ]
  }
}
