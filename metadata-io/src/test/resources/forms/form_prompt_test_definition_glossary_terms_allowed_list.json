{
	"on": {
	  "types": ["dataset", "container", "dataJob", "dataFlow", "chart", "dashboard", "mlModel", "mlModelGroup", "mlFeatureTable", "mlFeature", "mlPrimaryKey", "glossaryTerm", "glossaryNode", "domain", "dataProduct"],
	  "conditions": {
		"or": [
		  {
			"property": "forms.incompleteForms.urn",
			"operator": "equals",
			"values": ["urn:li:form:test"]
		  },
		  {
			"property": "forms.completedForms.urn",
			"operator": "equals",
			"values": ["urn:li:form:test"]
		  }
		]
	  }
	},
	"rules": {
	  "or": [
		{
		  "property": "glossaryTerms.terms.urn",
		  "operator": "contains_any",
		  "values": ["urn:li:glossaryTerm:test1"]
		},
		{
		  "property": "glossaryTerms.terms.urn.glossaryTermInfo.parentNode",
		  "operator": "contains_any",
		  "values": ["urn:li:glossaryNode:test"]
		}
	  ]
	},
	"actions": {
	  "passing": [],
	  "failing": [
		{
		  "type": "SET_FORM_PROMPT_INCOMPLETE",
		  "params": {
			"formUrn": "urn:li:form:test",
			"formPromptId": "test-id"
		  }
		}
	  ]
	}
  }